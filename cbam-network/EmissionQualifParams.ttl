###  https://purl.org/cbam/emissionsqualifyingparameters/parameterValueNumeric
emissionsqualifyingparameters:parameterValueNumeric rdf:type owl:DatatypeProperty ;
                                                    rdfs:subPropertyOf owl:topDataProperty ;
                                                    rdfs:domain [ rdf:type owl:Class ;
                                                                  owl:unionOf ( emissionsqualifyingparameters:Aluminium_scrap_usage
                                                                                emissionsqualifyingparameters:Steel_pre-consumer_scrap
                                                                                emissionsqualifyingparameters:Steel_product_scrap_usage
                                                                              )
                                                                ] ;
                                                    rdfs:range xsd:int ,
                                                               xsd:integer ;
                                                    rdfs:label "parameterValueNumeric" .


###  https://purl.org/cbam/emissionsqualifyingparameters/parameterValuePercentage
emissionsqualifyingparameters:parameterValuePercentage rdf:type owl:DatatypeProperty ;
                                                       rdfs:subPropertyOf owl:topDataProperty ;
                                                       rdfs:domain [ rdf:type owl:Class ;
                                                                     owl:unionOf ( emissionsqualifyingparameters:Aluminium_pre-consumer_scrap
                                                                                   emissionsqualifyingparameters:Ammonia_concentration
                                                                                   emissionsqualifyingparameters:Ammonium_Nitrogen_content
                                                                                   emissionsqualifyingparameters:Carbon_content_of_iron_or_steel
                                                                                   emissionsqualifyingparameters:Chromium_content
                                                                                   emissionsqualifyingparameters:Clinker_factor
                                                                                   emissionsqualifyingparameters:Content_of_other_alloy_elements
                                                                                   emissionsqualifyingparameters:Manganese_content
                                                                                   emissionsqualifyingparameters:Nickel_content
                                                                                   emissionsqualifyingparameters:Nitrate_Nitrogen_content
                                                                                   emissionsqualifyingparameters:Nitric_acid_concentration
                                                                                   emissionsqualifyingparameters:Non_Aluminium_content
                                                                                   emissionsqualifyingparameters:Non_Iron_content
                                                                                   emissionsqualifyingparameters:Other_Nitrogen_content
                                                                                   emissionsqualifyingparameters:Steel_pre-consumer_scrap
                                                                                   emissionsqualifyingparameters:Urea_Nitrogen_content
                                                                                   emissionsqualifyingparameters:Urea_purity
                                                                                 )
                                                                   ] ;
