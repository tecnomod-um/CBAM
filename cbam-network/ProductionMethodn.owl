        <dcterms:creator>
            <rdf:Description>
                <foaf:name>Astrid Duque Ramos</foaf:name>
            </rdf:Description>
        </dcterms:creator>
        <dcterms:description>This ontology represents the code list for the &apos;Production Method&apos; as defined by the Carbon Border Adjustment Mechanism (CBAM) Report.</dcterms:description>
        <dcterms:hasVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">&lt;https://purl.org/cbam/Production_Method/1.0&gt;</dcterms:hasVersion>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-21</dcterms:issued>
        <dcterms:license>&lt;http://creativecommons.org/licenses/by/4.0/&gt;</dcterms:license>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-21</dcterms:modified>
        <dcterms:publisher>Siemens Energy</dcterms:publisher>
        <dcterms:source>Report Structure ver 18.0.xlsx  &lt;https://taxation-customs.ec.europa.eu/carbon-border-adjustment-mechanism_en#where-to-report&gt;</dcterms:source>
        <dcterms:title rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">Production Method</dcterms:title>
        <vann:preferredNamespacePrefix>&lt;https://purl.org/cbam/Production_Method/&gt;</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>&lt;https://purl.org/cbam/Production_Method/&gt;</vann:preferredNamespaceUri>
